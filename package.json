{
  "name": "code-indicator",
  "displayName": "Code Indicator",
  "description": "Copy or send the current selection location in an rg-friendly format.",
  "version": "1.0.4",
  "publisher": "Yanun",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanun0323/code-indicator.git"
  },
  "keywords": [
    "codex",
    "claude-code",
    "opencode",
    "cli",
    "agent",
    "selection",
    "terminal"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:codeIndicator.sendSelectionLocationToActiveTerminal",
    "onCommand:codeIndicator.copySelectionLocation",
    "onCommand:codeIndicator.copySelectionLocationAndSendToActiveTerminal",
    "onCommand:codeIndicator.toggleView",
    "onCommand:codeIndicator.spawnTerminal",
    "onCommand:codeIndicator.killTerminal",
    "onCommand:codeIndicator.restartTerminal",
    "onCommand:codeIndicator.openSettings",
    "onView:codeIndicator.panel"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "configuration": {
      "title": "Code Indicator",
      "properties": {
        "codeIndicator.contextMenu.copyLocation": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Show Copy Location in the editor context menu."
        },
        "codeIndicator.contextMenu.sendLocationToTerminal": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Show Send Location to Terminal in the editor context menu."
        },
        "codeIndicator.contextMenu.copyAndSendLocationToTerminal": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Show Copy and Send Location to Terminal in the editor context menu."
        },
        "codeIndicator.terminal.focusAfterSend": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Focus the active terminal after sending a location."
        },
        "codeIndicator.terminal.startupCommand": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Run this command when the Code Indicator terminal is spawned, reloaded, or auto-started by opening the view. Leave empty to run nothing."
        },
        "codeIndicator.terminal.trailingCharacter": {
          "type": "string",
          "enum": [
            "space",
            "newline"
          ],
          "default": "space",
          "scope": "resource",
          "description": "Choose the trailing character sent after the location.",
          "enumDescriptions": [
            "Append a space after the location without submitting the terminal input.",
            "Submit the terminal input after the location."
          ]
        }
      }
    },
    "commands": [
      {
        "command": "codeIndicator.sendSelectionLocationToActiveTerminal",
        "title": "Send Location to Terminal",
        "category": "Code Indicator"
      },
      {
        "command": "codeIndicator.copySelectionLocation",
        "title": "Copy Location",
        "category": "Code Indicator"
      },
      {
        "command": "codeIndicator.copySelectionLocationAndSendToActiveTerminal",
        "title": "Copy and Send Location to Terminal",
        "category": "Code Indicator"
      },
      {
        "command": "codeIndicator.toggleView",
        "title": "Open Code Indicator View",
        "category": "Code Indicator"
      },
      {
        "command": "codeIndicator.spawnTerminal",
        "title": "Spawn Terminal",
        "category": "Code Indicator",
        "icon": "$(plus)",
        "enablement": "!codeIndicator.terminalLive"
      },
      {
        "command": "codeIndicator.killTerminal",
        "title": "Kill Terminal",
        "category": "Code Indicator",
        "icon": "$(trash)",
        "enablement": "codeIndicator.terminalLive"
      },
      {
        "command": "codeIndicator.restartTerminal",
        "title": "Restart Terminal",
        "category": "Code Indicator",
        "icon": "$(refresh)"
      },
      {
        "command": "codeIndicator.openSettings",
        "title": "Open Settings",
        "category": "Code Indicator",
        "icon": "$(gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeIndicator",
          "title": "Code Indicator",
          "icon": "$(console)"
        }
      ]
    },
    "views": {
      "codeIndicator": [
        {
          "id": "codeIndicator.panel",
          "name": "Code Indicator",
          "type": "webview",
          "visibility": "visible"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "codeIndicator.copySelectionLocation",
          "when": "config.codeIndicator.contextMenu.copyLocation",
          "group": "codeIndicator@1"
        },
        {
          "command": "codeIndicator.sendSelectionLocationToActiveTerminal",
          "when": "config.codeIndicator.contextMenu.sendLocationToTerminal",
          "group": "codeIndicator@2"
        },
        {
          "command": "codeIndicator.copySelectionLocationAndSendToActiveTerminal",
          "when": "config.codeIndicator.contextMenu.copyAndSendLocationToTerminal",
          "group": "codeIndicator@3"
        }
      ],
      "view/title": [
        {
          "command": "codeIndicator.spawnTerminal",
          "when": "view == codeIndicator.panel && !codeIndicator.terminalLive",
          "group": "navigation@1"
        },
        {
          "command": "codeIndicator.killTerminal",
          "when": "view == codeIndicator.panel && codeIndicator.terminalLive",
          "group": "navigation@2"
        },
        {
          "command": "codeIndicator.restartTerminal",
          "when": "view == codeIndicator.panel",
          "group": "navigation@3"
        },
        {
          "command": "codeIndicator.openSettings",
          "when": "view == codeIndicator.panel",
          "group": "navigation@4"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/**/*.test.js",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "node-pty": "1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.4.5"
  }
}
